APP_NAME=AI Agent Chat Platform
DEBUG=false
# Required. The OpenAI SDK validates this at construction time, so it
# must be non-empty EVEN when OPENAI_BASE_URL points at a gateway that
# doesn't care about OpenAI auth — set it to whatever token the gateway
# itself expects (or any placeholder like "sk-proxy" if the gateway
# ignores auth).
OPENAI_API_KEY=
# Optional — point at an OpenAI-compatible gateway / proxy (e.g. a
# company-hosted LiteLLM, Azure OpenAI endpoint, on-prem inference stack).
# Leave blank to hit api.openai.com directly. OPENAI_API_KEY is still
# required even when this is set (see note above).
# OPENAI_BASE_URL=https://llm-gateway.my-company.internal/v1
OPENAI_BASE_URL=
LLM_MODEL=gpt-5
# Sub-agent LLM (parse_node llm-mode + llm_node calls inside sub-agent
# templates). Lower-temperature workload — extraction + structured output
# rather than reasoning. Defaults to gpt-4.1.
SUB_AGENT_LLM_MODEL=gpt-4.1
# Reasoning effort for gpt-5 / o-family models.
# minimal | low | medium | high  (default: low — fast routing + light synthesis)
LLM_REASONING_EFFORT=low
# Reasoning-model detection.
#   auto  — match name against `^(o[1-9]\b|gpt-5)`. Handles dated names
#           like gpt-5-2025-01-01 automatically.
#   true  — force reasoning handling (use when a gateway-prefixed name
#           like "my-proxy/gpt-5-2025-01-01" bypasses the regex).
#   false — force non-reasoning handling.
LLM_IS_REASONING=auto
# Run an LLM + embedding ping at app startup to verify the key / gateway
# work before the first user turn. Adds ~0.5–3s per boot. Set to "false"
# if the hot-reload dev loop gets annoying.
LLM_STARTUP_CHECK=true
# Hard cap on Planner ↔ tool_execute loop iterations per turn. Safety
# valve against runaway tool-calling. Default 15 is well above the
# two-phase soft cap (which lives in nodes.py) and only fires on bugs.
MAX_AGENT_ITERATIONS=15
# Tagged into every [turn_summary.v1] log line so rollback analysis can
# compare turn-shape distributions across prompt versions. Bump when the
# Widget-vs-prose / response-strategy section in enrichment.py changes.
PLANNER_PROMPT_REVISION=v2026-04-22-compound-prose-default
EMBEDDING_MODEL=text-embedding-3-large
# OpenAIEmbeddings normally pre-counts tokens client-side via tiktoken,
# which downloads BPE files from openaipublic.blob.core.windows.net on
# first use. If your server is firewalled from Azure blob storage but
# can reach the LLM gateway, set this to false — the API will count
# tokens server-side instead. Symptom of needing this:
#   "Failed to resolve 'openaipublic.blob.core.windows.net'"
OPENAI_EMBEDDINGS_TIKTOKEN_ENABLED=true
CORS_ORIGINS=["http://localhost:6001"]

# LangSmith observability (only telemetry we emit — OTel/APM are hard-disabled).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=finchat
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false

# --- Logging ---
# Read directly via os.getenv (separate from the pydantic Settings above),
# because the logging system has to configure itself BEFORE pydantic loads.
#
# LOG_LEVEL — DEBUG | INFO | WARNING | ERROR  (default: INFO)
#   DEBUG turns on every internal app log line, including router decisions,
#   tool execution, and turn-summary lines that are normally already at INFO.
# LOG_LEVEL=INFO
#
# LOG_FORMAT — "json" for one-JSON-object-per-line (good for log shipping);
#              anything else for the human-readable formatter.
# LOG_FORMAT=
#
# LOG_DIR — when set, ALSO writes rotating files to <dir>/info.log and
#           <dir>/error.log (10 MB × 5 backups). Stdout always stays on.
# LOG_DIR=./logs
#
# Note: DEBUG=true above is a separate knob — it only turns on SQLAlchemy
# query echo, not Python log verbosity.
