APP_NAME=AI Agent Chat Platform
DEBUG=false
# Required. The OpenAI SDK validates this at construction time, so it
# must be non-empty EVEN when OPENAI_BASE_URL points at a gateway that
# doesn't care about OpenAI auth — set it to whatever token the gateway
# itself expects (or any placeholder like "sk-proxy" if the gateway
# ignores auth).
OPENAI_API_KEY=
# Optional — point at an OpenAI-compatible gateway / proxy (e.g. a
# company-hosted LiteLLM, Azure OpenAI endpoint, on-prem inference stack).
# Leave blank to hit api.openai.com directly. OPENAI_API_KEY is still
# required even when this is set (see note above).
# OPENAI_BASE_URL=https://llm-gateway.my-company.internal/v1
OPENAI_BASE_URL=
LLM_MODEL=gpt-5
LLM_REASONING_EFFORT=low
EMBEDDING_MODEL=text-embedding-3-large
CORS_ORIGINS=["http://localhost:6001"]

# LangSmith observability (only telemetry we emit — OTel/APM are hard-disabled).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=finchat
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
